POSTGRES_USER=polyarb
POSTGRES_PASSWORD=polyarb_dev
POSTGRES_DB=polyarb
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
REDIS_URL=redis://redis:6379/0
OPENAI_API_KEY=sk-your-key-here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=384
GAMMA_API_BASE=https://gamma-api.polymarket.com
CLOB_API_BASE=https://clob.polymarket.com
POLL_INTERVAL_SECONDS=30
RATE_LIMIT_RPS=2
FETCH_ORDER_BOOKS=false
MAX_SNAPSHOT_MARKETS=100
LOG_LEVEL=INFO

# Detector settings
SIMILARITY_THRESHOLD=0.82
SIMILARITY_TOP_K=20
DETECTOR_BATCH_SIZE=100
CLASSIFIER_MODEL=gpt-4o-mini
DETECTION_INTERVAL_SECONDS=60

# Optimizer settings
FW_MAX_ITERATIONS=200
FW_GAP_TOLERANCE=0.001
FW_IP_TIMEOUT_MS=5000
OPTIMIZER_INTERVAL_SECONDS=30
OPTIMIZER_MIN_EDGE=0.03
OPTIMIZER_SKIP_CONDITIONAL=true

# Simulator settings
INITIAL_CAPITAL=10000.0
MAX_POSITION_SIZE=100.0
FEE_RATE=0.02
SLIPPAGE_MODEL=vwap
SIMULATOR_INTERVAL_SECONDS=60

# Dashboard settings
DASHBOARD_PORT=8080

# Live trading settings (OFF by default — requires manual enable)
LIVE_TRADING_ENABLED=false
LIVE_TRADING_DRY_RUN=true
LIVE_TRADING_API_KEY=
LIVE_TRADING_PRIVATE_KEY=
LIVE_TRADING_CHAIN_ID=137
LIVE_TRADING_BANKROLL=100.0
LIVE_TRADING_MAX_POSITION_SIZE=10.0
LIVE_TRADING_SCALE_FACTOR=0.01
LIVE_TRADING_MIN_EDGE=0.03
LIVE_TRADING_MAX_DAILY_LOSS_PCT=10.0
