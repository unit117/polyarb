POSTGRES_USER=polyarb
POSTGRES_PASSWORD=changeme
POSTGRES_DB=polyarb
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
REDIS_URL=redis://redis:6379/0
OPENAI_API_KEY=sk-your-key-here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=384
GAMMA_API_BASE=https://gamma-api.polymarket.com
CLOB_API_BASE=https://clob.polymarket.com
POLL_INTERVAL_SECONDS=30
RATE_LIMIT_RPS=2
FETCH_ORDER_BOOKS=false
MAX_SNAPSHOT_MARKETS=100
LOG_LEVEL=INFO

# Detector settings
SIMILARITY_THRESHOLD=0.82
SIMILARITY_TOP_K=20
DETECTOR_BATCH_SIZE=100
CLASSIFIER_MODEL=gpt-4.1-mini
CLASSIFIER_PROMPT_ADAPTER=auto
DETECTION_INTERVAL_SECONDS=60

# Optimizer settings
FW_MAX_ITERATIONS=200
FW_GAP_TOLERANCE=0.001
FW_IP_TIMEOUT_MS=5000
OPTIMIZER_INTERVAL_SECONDS=30
OPTIMIZER_MIN_EDGE=0.03
OPTIMIZER_SKIP_CONDITIONAL=true

# Simulator settings
INITIAL_CAPITAL=10000.0
MAX_POSITION_SIZE=100.0
SLIPPAGE_MODEL=vwap
SIMULATOR_INTERVAL_SECONDS=60
# SIMULATOR_RESET_EPOCH=2026-03-21T15:02:00Z  # Filter dashboard to only show data after this timestamp

# Circuit breaker settings
CB_MAX_DAILY_LOSS=500.0
CB_MAX_POSITION_PER_MARKET=200.0
CB_MAX_DRAWDOWN_PCT=10.0
CB_MAX_CONSECUTIVE_ERRORS=5
CB_COOLDOWN_SECONDS=300

# Kalshi settings (OFF by default)
KALSHI_ENABLED=false
KALSHI_API_KEY=
KALSHI_API_SECRET=
KALSHI_POLL_INTERVAL_SECONDS=120
KALSHI_MAX_MARKETS=500
KALSHI_RATE_LIMIT_RPS=1.5

# Dashboard settings
DASHBOARD_PORT=8080

# Live trading settings (OFF by default — requires manual enable)
LIVE_TRADING_ENABLED=false
LIVE_TRADING_DRY_RUN=true
LIVE_TRADING_API_KEY=
LIVE_TRADING_PRIVATE_KEY=
LIVE_TRADING_CHAIN_ID=137
LIVE_TRADING_SIGNATURE_TYPE=0
LIVE_TRADING_FUNDER=
LIVE_TRADING_BANKROLL=100.0
LIVE_TRADING_MAX_POSITION_SIZE=10.0
LIVE_TRADING_MIN_EDGE=0.03
LIVE_TRADING_MAX_DAILY_LOSS_PCT=10.0
LIVE_SNAPSHOT_INTERVAL_SECONDS=300
LIVE_STATUS_HEARTBEAT_SECONDS=30
LIVE_RECONCILE_INTERVAL_SECONDS=5
