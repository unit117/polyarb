# Required: Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Optional: model override (defaults to claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Optional: working directory for the agent (defaults to repo root)
# AGENT_WORK_DIR=/home/ubuntu/polyarb

# Optional: permission mode
# AGENT_PERMISSION_MODE=bypassPermissions
